{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fredoka|Noto Sans SC|ZCOOL KuaiLe))/i]",
        "message": "Font not provided by the design system. Available: Fredoka, Noto Sans SC, ZCOOL KuaiLe."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|ring|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, ring, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|icon|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, variant, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:coral|sprout|sun|grape|neutral)$/]",
        "message": "<Badge> tone must be one of 'coral' | 'sprout' | 'sun' | 'grape' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|block|disabled|icon|iconRight|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, block, disabled, icon, iconRight, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|sun|sprout)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'sun' | 'sprout'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|hover|gradient|header|headerHeight|pad|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, hover, gradient, header, headerHeight, pad, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:plain|raised|gradient)$/]",
        "message": "<Card> variant must be one of 'plain' | 'raised' | 'gradient'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:as|value|onChange|placeholder|label|icon|rows|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: as, value, onChange, placeholder, label, icon, rows, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:input|textarea)$/]",
        "message": "<Input> as must be one of 'input' | 'textarea'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Mascot'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|pose|base|size|anim|glow|alt|style|key|ref|className|style|children)$/]",
        "message": "<Mascot> doesn't accept that prop. Declared props: src, pose, base, size, anim, glow, alt, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Mascot'] > JSXAttribute[name.name='pose'] > Literal[value!=/^(?:wave|jump|superhero|welcome|empty|ready|walk|sit|writing|meditate|surf|analyze|upgrade|lookup|done|crash|approve|photographer|inspect|lift|curator|cook|sleep|paint|dance|error)$/]",
        "message": "<Mascot> pose must be one of 'wave' | 'jump' | 'superhero' | 'welcome' | 'empty' | 'ready' | 'walk' | 'sit' | 'writing' | 'meditate' | 'surf' | 'analyze' | 'upgrade' | 'lookup' | 'done' | 'crash' | 'approve' | 'photographer' | 'inspect' | 'lift' | 'curator' | 'cook' | 'sleep' | 'paint' | 'dance' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Mascot'] > JSXAttribute[name.name='anim'] > Literal[value!=/^(?:float|bob|twinkle|none)$/]",
        "message": "<Mascot> anim must be one of 'float' | 'bob' | 'twinkle' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|size|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, disabled, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Switch> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|active|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, active, onClick, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
