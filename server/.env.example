# 薯包AI 后端配置
# 复制为 .env 并填入真实值

# LLM API 配置（二选一）
# 方式A：兼容 OpenAI 格式的 API（如中转站）
LLM_API_KEY=sk-REDACTED-KEY-PLACEHOLDER
LLM_BASE_URL=https://img-cn.65535.space
LLM_MODEL=claude-sonnet-4-6

# 方式B：Anthropic 直连（如中转站不支持 LLM）
ANTHROPIC_API_KEY=

# 图片生成 API（必须配）
IMAGE_API_KEY=sk-REDACTED-KEY-PLACEHOLDER
IMAGE_BASE_URL=https://img-cn.65535.space
IMAGE_MODEL=gpt-image-2

# 服务器端口
PORT=3002
