# ── 薯包AI 环境变量配置 ──
# 复制为 .env 后填入真实密钥

# LLM API（内容分析 - 主力模型）
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Mini API（Vision 分析 - 参考图理解）
MINI_API_KEY=sk-your-key-here
MINI_BASE_URL=https://api.65535.space
MINI_MODEL=gpt-5.4-mini

# 图片生成 API（GPT-Image-2 中转站）
IMAGE_API_KEY=sk-your-key-here
IMAGE_BASE_URL=https://img-cn.65535.space
IMAGE_MODEL=gpt-image-2

# 服务端口
PORT=3001
